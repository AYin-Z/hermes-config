# Hermes Agent Configuration — MemOS Memory Provider
# ====================================================
# Copy this file to config.yaml and fill in your own values.
# API keys and secrets belong in ~/.hermes/.env, NOT in config.yaml.

model:
  default: deepseek-v4-pro
  provider: custom:deepseek-official
providers: {}
fallback_providers: []
credential_pool_strategies: {}
toolsets:
  - hermes-cli

agent:
  max_turns: 100
  gateway_timeout: 1200
  restart_drain_timeout: 60
  api_max_retries: 3
  service_tier: ''
  tool_use_enforcement: auto
  gateway_timeout_warning: 900
  gateway_notify_interval: 180
  gateway_auto_continue_freshness: 3600
  image_input_mode: auto
  disabled_toolsets: []

memory:
  mode: auto
  tool_name: memory_search
  provider: memtensor
  recall_limit: 10
  auto_recall: true

# MemOS Memory Provider Plugin
# Plugin path: ~/.hermes/hermes-agent/plugins/memory/memtensor
# Config: see README.md for installation instructions
